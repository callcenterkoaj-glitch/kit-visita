<script>
// ── EmailJS config (reemplaza con tus credenciales) ──
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbx_p30i9-NePyxaocU0H71TlwN7B9PAlvjj20KWaGL2UJAnIiQ5yXUdTgUDOv-3VIzXdA/exec';

// ── SECCIONES CHECK ──
const SECS = {
  'items-acceso':     { pId:'spct2', tId:'pct2', items:[
    {id:'link-anclado',  lbl:'El link del sitio esta anclado y guardado en los dispositivos de la tienda'},
    {id:'actualizacion', lbl:'Conocen la actualizacion reciente (carritos pausados e historial de pedidos) y han revisado el material enviado'},
  ]},
  'items-facturacion':{ pId:'spct3', tId:'pct3', items:[
    {id:'fact-proceso', lbl:'Conocen como generar el proceso de facturacion de la herramienta'},
    {id:'venta-espera', lbl:'Conocen que pasa si se deja una venta en espera'},
    {id:'borra-linea',  lbl:'Conocen que pasa si se borra una linea del pedido'},
    {id:'borra-bolsa',  lbl:'Conocen que pasa si se borra la bolsa del pedido'},
  ]},
  'items-despacho':   { pId:'spct4', tId:'pct4', items:[
    {id:'oms-anclado',      lbl:'Tiene anclada la pagina del OMS'},
    {id:'oms-seguimiento',  lbl:'Conoce como hacerle seguimiento a un pedido en el OMS'},
    {id:'tiempos-despacho', lbl:'Conocen los tiempos de despacho'},
    {id:'canales-com',      lbl:'Conoce los canales de comunicacion y sus accesos directos'},
  ]},
  'items-materiales': { pId:'spct5', tId:'pct5', items:[
    {id:'material-visto', lbl:'Han visto los contenidos y material enviados por comunidades, grupos WA y correos'},
    {id:'link-dudas',     lbl:'Conocen el link de consulta cuando tengan dudas del proceso'},
  ]},
};

const ST = { tg:{}, ch:{}, casos:{}, stars:{} };

// ── BUILD DOM ──
function buildCI({id,lbl}, sk) {
  return `<div class="ci" id="ci-${id}">
    <div class="cih">
      <span class="cil">${lbl}</span>
      <div class="kg">
        <button class="kb" onclick="setCheck('${id}','yes',this,'${sk}')">Lo conocen</button>
        <button class="kb" onclick="setCheck('${id}','no',this,'${sk}')">No lo conocen</button>
      </div>
    </div>
    <div class="obsp" id="obs-${id}">
      <span class="oblbl">Que paso</span>
      <textarea placeholder="Describe la situacion observada..." oninput="ST.ch['${id}'].obs=this.value"></textarea>
    </div>
  </div>`;
}

function initDOM() {
  for (const [sk, sec] of Object.entries(SECS)) {
    document.getElementById(sk).innerHTML = sec.items.map(i=>buildCI(i,sk)).join('');
    sec.items.forEach(i=>{ ST.ch[i.id]={val:'',obs:''}; });
  }
}

// ── TABS ──
function goTab(n) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('on'));
  document.getElementById('page'+n).classList.add('on');
  document.getElementById('tab'+n).classList.add('on');
  window.scrollTo(0,0);
}

// ── SYNC HERO ──
function syncH() {
  const nm = document.getElementById('storeName').value||'—';
  const ld = document.getElementById('visitLeader').value||'—';
  const dt = document.getElementById('visitDate').value;
  document.getElementById('hTienda').textContent = nm;
  document.getElementById('hLider').textContent  = ld;
  document.getElementById('hFecha').textContent  = dt
    ? new Date(dt+'T12:00:00').toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'})
    : '—';
}

// ── TOGGLE ──
function setTg(btn, id, val) {
  btn.closest('.tg').querySelectorAll('.tgb').forEach(b=>b.classList.remove('ay','an'));
  btn.classList.add(val==='yes'?'ay':'an');
  ST.tg[id]=val;
}

// ── CHECK ──
function setCheck(id, val, btn, sk) {
  document.getElementById('ci-'+id).querySelectorAll('.kb').forEach(b=>b.classList.remove('ky','kn'));
  btn.classList.add(val==='yes'?'ky':'kn');
  ST.ch[id].val=val;
  document.getElementById('obs-'+id).classList.toggle('vis', val==='no');
  calcCkPct(sk);
}

// ── PCT ──
function setPct(cEl, tEl, pct) {
  const c=document.getElementById(cEl), t=document.getElementById(tEl);
  if(c){c.textContent=pct+'%';c.classList.toggle('done',pct===100);c.classList.toggle('half',pct>=50&&pct<100);}
  if(t) t.textContent=pct+'%';
}
function p0(){
  const f=['storeName','storeCity','visitDate','visitLeader','visitResponsible','visitRole','numCajeros','numAsesores']
    .filter(id=>document.getElementById(id)?.value!=='').length;
  setPct('spct0','pct0',Math.round(f/8*100));
}
function p1(){
  let f=0;
  if(ST.tg['lc']) f++;
  if(document.getElementById('cajerosCap').value!=='') f++;
  if(ST.tg['ac']) f++;
  setPct('spct1','pct1',Math.round(f/3*100));
}
function calcCkPct(sk){
  const sec=SECS[sk]; if(!sec) return;
  const fil=sec.items.filter(i=>ST.ch[i.id]?.val!=='').length;
  setPct(sec.pId,sec.tId,Math.round(fil/sec.items.length*100));
}

// ── CASOS ──
function togC(h){
  const b=h.nextElementSibling, c=h.querySelector('.chev');
  b.classList.toggle('vis'); c.classList.toggle('open');
}
function setC(e,id,val,btn){
  e.stopPropagation();
  btn.closest('.cest').querySelectorAll('.eb').forEach(b=>b.classList.remove('enp','ep'));
  btn.classList.add(val==='nop'?'enp':'ep');
  ST.casos[id]=val;
  if(val==='pres'){const h=btn.closest('.ch');h.nextElementSibling.classList.add('vis');h.querySelector('.chev').classList.add('open');}
}
function swRole(btn,r){
  document.querySelectorAll('.rt').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.cg').forEach(g=>g.classList.remove('on'));
  document.getElementById('casos-'+r).classList.add('on');
}

// ── STARS ──
function setStar(gid,val,btn){
  document.getElementById(gid).querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('on',i<val));
  ST.stars[gid]=val;
}

// ── RESULTADO ──
function calcResultado(){
  const allCh = Object.values(ST.ch);
  const total = allCh.length;
  const pos   = allCh.filter(c=>c.val==='yes').length;
  const neg   = allCh.filter(c=>c.val==='no').length;
  const sinR  = allCh.filter(c=>c.val==='').length;
  const pct   = total>0 ? Math.round(pos/total*100) : 0;
  const apr   = pct>=70;

  // Recopilar items fallidos con sus labels
  const fallidos = [];
  for(const [sk, sec] of Object.entries(SECS)){
    for(const item of sec.items){
      if(ST.ch[item.id]?.val==='no' || ST.ch[item.id]?.val===''){
        fallidos.push({lbl: item.lbl, val: ST.ch[item.id]?.val});
      }
    }
  }

  const failHtml = fallidos.length
    ? fallidos.map(f=>`<div class="fail-item">${f.lbl}${f.val===''?' <em style="opacity:.6">(sin respuesta)</em>':''}</div>`).join('')
    : '<div class="fail-item" style="border-color:var(--gbd);background:var(--gbg);color:var(--green)">Todos los items respondidos positivamente</div>';

  document.getElementById('resultado-wrap').innerHTML = `
  <div class="resbox ${apr?'apr':'rej'}">
    <div class="restit ${apr?'gv':'rv'}">${apr?'Visita Aprobada':'Visita No Aprobada'}</div>
    <div class="ressub">${apr
      ? 'La tienda demuestra un buen nivel de conocimiento y adopcion de Pasillo Infinito.'
      : 'Se identificaron oportunidades de mejora que requieren seguimiento y refuerzo.'}</div>
    <div class="pbar-w"><div class="pbar-f" style="width:${pct}%"></div></div>
    <div class="res-grid">
      <div class="ri"><div class="rl">Respuestas positivas</div><div class="rv ok">${pos} de ${total}</div></div>
      <div class="ri"><div class="rl">Porcentaje de conocimiento</div><div class="rv ${apr?'ok':'fail'}">${pct}%</div></div>
      <div class="ri clickable" onclick="togFail(this)" title="Clic para ver detalle">
        <div class="rl">Items a reforzar</div>
        <div class="rv fail">${fallidos.length} item${fallidos.length!==1?'s':''}</div>
        <div class="hint">Clic para ver cuales &darr;</div>
        <div class="fail-list" id="fail-list">${failHtml}</div>
      </div>
      <div class="ri"><div class="rl">Sin respuesta</div><div class="rv">${sinR}</div></div>
    </div>
  </div>`;

  document.getElementById('resultado-wrap').scrollIntoView({behavior:'smooth',block:'start'});

  // Enviar a Google Sheets
  enviarASheets(apr, pct, fallidos);
}

function togFail(card){
  const fl=card.querySelector('.fail-list');
  fl.classList.toggle('vis');
  card.querySelector('.hint').textContent = fl.classList.contains('vis') ? 'Clic para ocultar ↑' : 'Clic para ver cuales ↓';
}

// ── ENVIAR A GOOGLE SHEETS ──
function enviarASheets(apr, pct, fallidos){
  const g = id => document.getElementById(id)?.value||'';
  const ck = id => ST.ch[id]?.val==='yes'?'Lo conocen':ST.ch[id]?.val==='no'?'No lo conocen':'—';
  const ob = id => ST.ch[id]?.obs||'';

  const payload = {
    tienda:              g('storeName'),
    ciudad:              g('storeCity'),
    fecha:               g('visitDate'),
    lider:               g('visitLeader'),
    responsable:         g('visitResponsible'),
    cargo:               g('visitRole'),
    cajeros:             g('numCajeros'),
    asesores:            g('numAsesores'),
    lider_cap:           ST.tg['lc']||'—',
    cajeros_cap:         g('cajerosCap'),
    asesor_cap:          ST.tg['ac']||'—',
    link_anclado:        ck('link-anclado'),
    link_anclado_obs:    ob('link-anclado'),
    actualizacion:       ck('actualizacion'),
    actualizacion_obs:   ob('actualizacion'),
    fact_proceso:        ck('fact-proceso'),
    fact_proceso_obs:    ob('fact-proceso'),
    venta_espera:        ck('venta-espera'),
    venta_espera_obs:    ob('venta-espera'),
    borra_linea:         ck('borra-linea'),
    borra_linea_obs:     ob('borra-linea'),
    borra_bolsa:         ck('borra-bolsa'),
    borra_bolsa_obs:     ob('borra-bolsa'),
    oms_anclado:         ck('oms-anclado'),
    oms_anclado_obs:     ob('oms-anclado'),
    oms_seguimiento:     ck('oms-seguimiento'),
    oms_seguimiento_obs: ob('oms-seguimiento'),
    tiempos_despacho:    ck('tiempos-despacho'),
    tiempos_despacho_obs:ob('tiempos-despacho'),
    canales_com:         ck('canales-com'),
    canales_com_obs:     ob('canales-com'),
    material_visto:      ck('material-visto'),
    material_visto_obs:  ob('material-visto'),
    link_dudas:          ck('link-dudas'),
    link_dudas_obs:      ob('link-dudas'),
    enc1:                ST.stars['enc1']||'—',
    enc2:                ST.stars['enc2']||'—',
    enc3:                ST.stars['enc3']||'—',
    observaciones:       g('obsGenerales'),
    resultado:           apr ? 'APROBADA' : 'NO APROBADA',
    porcentaje:          pct + '%'
  };

  showToast('Guardando en base de datos...');

  fetch(SCRIPT_URL, {
    method: 'POST',
    mode: 'no-cors',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(() => showToast('Visita guardada en Google Sheets'))
  .catch(() => showToast('Error al guardar — exporta el Excel manualmente'));
}

// ── GUARDAR LOCAL ──
function guardarLocal(){
  const snap={
    storeName:document.getElementById('storeName').value,
    storeCity:document.getElementById('storeCity').value,
    visitDate:document.getElementById('visitDate').value,
    visitLeader:document.getElementById('visitLeader').value,
    visitResponsible:document.getElementById('visitResponsible').value,
    visitRole:document.getElementById('visitRole').value,
    numCajeros:document.getElementById('numCajeros').value,
    numAsesores:document.getElementById('numAsesores').value,
    cajerosCap:document.getElementById('cajerosCap').value,
    tg:{...ST.tg},ch:JSON.parse(JSON.stringify(ST.ch)),
    casos:{...ST.casos},stars:{...ST.stars},
    obs:document.getElementById('obsGenerales').value,
    ts:new Date().toISOString()
  };
  localStorage.setItem('kit_pi_'+Date.now(),JSON.stringify(snap));
  showToast('Borrador guardado');
}

// ── EXCEL ──
const gv = id => document.getElementById(id)?.value||'';
const yn = v  => v==='yes'?'Si':v==='no'?'No':'—';
const ck = id => ST.ch[id]?.val==='yes'?'Lo conocen':ST.ch[id]?.val==='no'?'No lo conocen':'—';
const ob = id => ST.ch[id]?.obs||'';
const cL = id => ST.casos[id]==='nop'?'No se ha presentado':ST.casos[id]==='pres'?'Se presento':'—';
const st = id => ST.stars[id]?ST.stars[id]+'/5':'—';

function exportarExcel(){
  const wb=XLSX.utils.book_new();
  const allCh=Object.values(ST.ch);
  const pos=allCh.filter(c=>c.val==='yes').length;
  const pct=allCh.length?Math.round(pos/allCh.length*100):0;
  const apr=pct>=70?'APROBADA':'NO APROBADA';

  const ws1=XLSX.utils.aoa_to_sheet([
    ['PASILLO INFINITO - KIT DE VISITA','','',''],['','','',''],
    ['DATOS GENERALES','','',''],
    ['Tienda',gv('storeName'),'Ciudad',gv('storeCity')],
    ['Fecha',gv('visitDate'),'Lider que visita',gv('visitLeader')],
    ['Responsable',gv('visitResponsible'),'Cargo',gv('visitRole')],
    ['','','',''],['INTEGRANTES DE LA TIENDA','','',''],
    ['Cajeros',gv('numCajeros'),'Asesores',gv('numAsesores')],
  ]);
  ws1['!cols']=[{wch:26},{wch:24},{wch:22},{wch:24}];
  XLSX.utils.book_append_sheet(wb,ws1,'Resumen');

  const ws2=XLSX.utils.aoa_to_sheet([
    ['CAPACITACION','',''],['','',''],
    ['Item','Respuesta',''],
    ['Lider se conecto a la capacitacion',yn(ST.tg['lc']),''],
    ['Cajeros conectados a la capacitacion',gv('cajerosCap')||'—',''],
    ['Algun asesor estuvo en la capacitacion',yn(ST.tg['ac']),''],
  ]);
  ws2['!cols']=[{wch:46},{wch:14},{wch:8}];
  XLSX.utils.book_append_sheet(wb,ws2,'Capacitacion');

  const ws3=XLSX.utils.aoa_to_sheet([
    ['CHECKLIST DE CONOCIMIENTO','','',''],['','','',''],
    ['RESULTADO',apr,'Conocimiento: '+pct+'%',''],['','','',''],
    ['Item','Estado','Observacion',''],
    ['-- ACCESO Y USO --','','',''],
    ['El link del sitio esta anclado en los dispositivos',ck('link-anclado'),ob('link-anclado'),''],
    ['Conocen actualizacion reciente (carritos, historial)',ck('actualizacion'),ob('actualizacion'),''],
    ['-- FACTURACION --','','',''],
    ['Conocen como generar el proceso de facturacion',ck('fact-proceso'),ob('fact-proceso'),''],
    ['Conocen que pasa si se deja una venta en espera',ck('venta-espera'),ob('venta-espera'),''],
    ['Conocen que pasa si se borra una linea del pedido',ck('borra-linea'),ob('borra-linea'),''],
    ['Conocen que pasa si se borra la bolsa del pedido',ck('borra-bolsa'),ob('borra-bolsa'),''],
    ['-- DESPACHO --','','',''],
    ['Tiene anclada la pagina del OMS',ck('oms-anclado'),ob('oms-anclado'),''],
    ['Conoce como hacer seguimiento en el OMS',ck('oms-seguimiento'),ob('oms-seguimiento'),''],
    ['Conocen los tiempos de despacho',ck('tiempos-despacho'),ob('tiempos-despacho'),''],
    ['Conoce los canales de comunicacion y accesos directos',ck('canales-com'),ob('canales-com'),''],
    ['-- MATERIALES --','','',''],
    ['Han visto contenidos enviados por WA, comunidades y correos',ck('material-visto'),ob('material-visto'),''],
    ['Conocen el link de consulta para dudas',ck('link-dudas'),ob('link-dudas'),''],
  ]);
  ws3['!cols']=[{wch:52},{wch:16},{wch:44},{wch:6}];
  XLSX.utils.book_append_sheet(wb,ws3,'Checklist');

  const ws4=XLSX.utils.aoa_to_sheet([
    ['CASOS FRECUENTES','',''],['','',''],
    ['Caso','Estado','Rol'],
    ['Cliente quiere cambiar direccion de entrega',cL('ca1'),'Administrador'],
    ['Pedido entregado pero cliente no lo recibio',cL('ca2'),'Administrador'],
    ['Sistema no permite facturar o se queda cargando',cL('ca3'),'Administrador'],
    ['Producto sin stock en sitio pero existe en tienda',cL('ca4'),'Administrador'],
    ['Carrito pausado no se puede retomar',cL('cc1'),'Cajero / Lider'],
    ['Cliente quiere saber estado del pedido',cL('cc2'),'Cajero / Lider'],
    ['Se borro linea del pedido por error',cL('cc3'),'Cajero / Lider'],
  ]);
  ws4['!cols']=[{wch:50},{wch:22},{wch:16}];
  XLSX.utils.book_append_sheet(wb,ws4,'Casos Frecuentes');

  const ws5=XLSX.utils.aoa_to_sheet([
    ['ENCUESTA DE PERCEPCION','',''],['','',''],
    ['Pregunta','Calificacion',''],
    ['Facilidad de uso para colaboradores',st('enc1'),''],
    ['Tiempos de recogida en tienda',st('enc2'),''],
    ['Aprovechamiento del potencial de Pasillo Infinito',st('enc3'),''],
    ['','',''],['OBSERVACIONES','',''],
    [gv('obsGenerales')||'(sin observaciones)','',''],
  ]);
  ws5['!cols']=[{wch:50},{wch:16},{wch:6}];
  XLSX.utils.book_append_sheet(wb,ws5,'Encuesta');

  const slug=(gv('storeName')||'tienda').replace(/\s+/g,'-').toLowerCase();
  const fech=gv('visitDate')||new Date().toISOString().slice(0,10);
  XLSX.writeFile(wb,`Kit-Visita_${slug}_${fech}.xlsx`);
  showToast('Excel exportado');
}

// ── TOAST ──
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}

// ── INIT ──
document.addEventListener('DOMContentLoaded',()=>{
  initDOM();
  document.getElementById('visitDate').value=new Date().toISOString().slice(0,10);
  syncH(); p0();
});
</script>
</body>
</html>
