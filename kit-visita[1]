<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kit de Visita – Pasillo Infinito</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<!-- EmailJS -->

<style>
:root {
  --bg:       #edf0f7;
  --surface:  #ffffff;
  --sf2:      #f4f6fb;
  --border:   #dce1ee;
  --border2:  #e8ecf6;
  --navy:     #1c3172;
  --navy2:    #253f9a;
  --lime:     #b8f000;
  --text:     #18213a;
  --text2:    #3a4868;
  --muted:    #74809e;
  --muted2:   #a5afc8;
  --green:    #166534;
  --gbg:      #f0fdf4;
  --gbd:      #bbf7d0;
  --red:      #991b1b;
  --rbg:      #fef2f2;
  --rbd:      #fecaca;
  --gold:     #92400e;
  --ybg:      #fffbeb;
  --ybd:      #fde68a;
  --r:        10px;
  --rs:       6px;
  --sh:       0 1px 3px rgba(28,49,114,.07),0 1px 2px rgba(28,49,114,.05);
  --shm:      0 4px 18px rgba(28,49,114,.13);
  --ft:       'DM Serif Display', Georgia, serif;
  --fb:       'Inter', system-ui, sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--fb);font-size:13.5px;line-height:1.65;min-height:100vh}

/* ── TOPBAR ── */
.topbar{background:var(--navy);padding:0 24px;display:flex;align-items:stretch;height:50px;position:sticky;top:0;z-index:100;box-shadow:var(--shm)}
.tb-brand{display:flex;align-items:center;gap:9px;padding-right:22px;border-right:1px solid rgba(255,255,255,.12);flex-shrink:0}
.tb-brand .name{font-family:var(--ft);font-size:17px;color:#fff;letter-spacing:.2px}
.tb-brand .name em{color:var(--lime);font-style:normal}
.dot{width:7px;height:7px;background:var(--lime);border-radius:50%;animation:blink 2.5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
.tab-nav{display:flex;align-items:stretch;flex:1;padding:0 14px;overflow-x:auto;scrollbar-width:none}
.tab-nav::-webkit-scrollbar{display:none}
.tbtn{display:flex;align-items:center;gap:6px;padding:0 13px;background:transparent;border:none;color:rgba(255,255,255,.48);font-family:var(--fb);font-size:11.5px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.tbtn:hover{color:rgba(255,255,255,.8)}
.tbtn.on{color:#fff;border-bottom-color:var(--lime)}
.tpct{background:rgba(255,255,255,.1);border-radius:100px;padding:1px 7px;font-size:9.5px;font-weight:700;color:rgba(255,255,255,.55)}
.tbtn.on .tpct{background:var(--lime);color:var(--navy)}
.tb-right{display:flex;align-items:center;gap:7px;padding-left:14px;border-left:1px solid rgba(255,255,255,.12);flex-shrink:0}
.bt{padding:5px 13px;border-radius:var(--rs);font-family:var(--fb);font-size:11px;font-weight:600;cursor:pointer;border:none;transition:all .18s;letter-spacing:.2px}
.bt-xl{background:var(--lime);color:var(--navy)}
.bt-xl:hover{background:#d4ff00}
.bt-dr{background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);border:1px solid rgba(255,255,255,.13)}
.bt-dr:hover{background:rgba(255,255,255,.18)}

/* ── PAGES ── */
.page{display:none}
.page.on{display:block}
.pi{max-width:860px;margin:0 auto;padding:30px 22px 90px}

/* ── HERO ── */
.hero{background:var(--navy);padding:38px 32px 30px;border-radius:var(--r);margin-bottom:22px;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;right:-60px;top:-60px;width:280px;height:280px;background:radial-gradient(circle,rgba(184,240,0,.09) 0%,transparent 70%);pointer-events:none}
.hbadge{display:inline-flex;align-items:center;gap:6px;background:rgba(184,240,0,.1);border:1px solid rgba(184,240,0,.2);padding:3px 12px;border-radius:100px;font-size:9.5px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase;color:var(--lime);margin-bottom:14px}
.hero h1{font-family:var(--ft);font-size:clamp(32px,6vw,56px);font-weight:400;line-height:1.0;letter-spacing:-.5px;color:#fff;margin-bottom:12px}
.hero h1 em{color:var(--lime);font-style:normal;display:block}
.hero-sub{font-size:12.5px;font-style:italic;color:rgba(255,255,255,.42);padding-left:12px;border-left:2px solid var(--lime);max-width:440px;line-height:1.55;margin-bottom:24px;font-family:var(--fb)}
.hmeta{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid rgba(255,255,255,.08);border-radius:var(--rs);overflow:hidden}
@media(max-width:580px){.hmeta{grid-template-columns:1fr 1fr}}
.hmi{padding:10px 14px;border-right:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.035)}
.hmi:last-child{border-right:none}
.hmi .hl{font-size:8.5px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.32);margin-bottom:3px}
.hmi .hv{font-family:var(--fb);font-size:12.5px;font-weight:600;color:#fff}
.hmi .hv.lime{color:var(--lime)}

/* ── CARD ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:22px 22px 18px;margin-bottom:16px;box-shadow:var(--sh)}
.ctitle{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:11px;border-bottom:1px solid var(--border2)}
.ctl{display:flex;align-items:center;gap:8px}
.ctbar{width:3px;height:16px;background:linear-gradient(to bottom,var(--lime),var(--navy2));border-radius:3px;flex-shrink:0}
.ctitle h2{font-family:var(--ft);font-size:16px;font-weight:400;letter-spacing:.1px;color:var(--navy)}
.spct{font-family:var(--fb);font-size:10px;font-weight:600;color:var(--muted);background:var(--sf2);border:1px solid var(--border);border-radius:100px;padding:2px 10px;transition:all .3s}
.spct.done{background:var(--gbg);border-color:var(--gbd);color:var(--green)}
.spct.half{background:var(--ybg);border-color:var(--ybd);color:var(--gold)}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
@media(max-width:560px){.g2,.g3{grid-template-columns:1fr}}

/* ── FIELD ── */
.field{display:flex;flex-direction:column;gap:4px}
.field label{font-size:9.5px;font-weight:700;letter-spacing:1.3px;text-transform:uppercase;color:var(--muted)}
.fi{background:var(--sf2);border:1px solid var(--border);border-radius:var(--rs);padding:9px 11px;color:var(--text);font-family:var(--fb);font-size:13px;outline:none;width:100%;transition:border-color .18s,background .18s}
.fi:focus{border-color:var(--navy2);background:#fff}
.fi::placeholder{color:var(--muted2)}
select.fi option{background:#fff;color:var(--text)}

/* ── SUB ── */
.sub{font-family:var(--ft);font-size:13px;font-style:italic;color:var(--muted);margin:16px 0 10px;display:flex;align-items:center;gap:8px}
.sub::after{content:'';flex:1;height:1px;background:var(--border2)}

/* ── DOTACION ── */
.drow{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px}
.df{background:var(--sf2);border:1px solid var(--border);border-radius:var(--rs);padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px}
.df label{font-size:12.5px;font-weight:500;color:var(--text2)}
.nin{width:60px;background:#fff;border:1.5px solid var(--border);border-radius:var(--rs);padding:6px 8px;color:var(--navy);font-family:var(--fb);font-size:14px;font-weight:700;text-align:center;outline:none;transition:border-color .18s}
.nin:focus{border-color:var(--navy2)}

/* ── NUM ROW ── */
.nr{display:flex;align-items:center;gap:12px;padding:11px 13px;background:var(--sf2);border:1px solid var(--border);border-radius:var(--rs);margin-bottom:7px;flex-wrap:wrap}
.nr label{flex:1;font-size:13px;font-weight:400;color:var(--text2);min-width:160px;line-height:1.4}

/* ── TOGGLE ── */
.tg{display:flex;gap:5px;flex-shrink:0}
.tgb{padding:5px 12px;border-radius:var(--rs);border:1.5px solid var(--border);background:#fff;color:var(--muted);font-family:var(--fb);font-size:11.5px;font-weight:600;cursor:pointer;transition:all .18s}
.tgb:hover{border-color:var(--navy2);color:var(--navy)}
.tgb.ay{background:var(--gbg);border-color:var(--gbd);color:var(--green)}
.tgb.an{background:var(--rbg);border-color:var(--rbd);color:var(--red)}

/* ── CHECK ITEM ── */
.ci{border:1px solid var(--border);border-radius:var(--rs);overflow:hidden;margin-bottom:7px;background:#fff;transition:border-color .18s}
.ci:focus-within{border-color:var(--navy2)}
.cih{display:flex;align-items:center;padding:10px 13px;gap:11px;flex-wrap:wrap;background:var(--sf2)}
.cil{flex:1;font-size:13px;font-weight:400;color:var(--text2);min-width:180px;line-height:1.4}
.kg{display:flex;gap:5px;flex-shrink:0}
.kb{padding:5px 11px;border-radius:var(--rs);border:1.5px solid var(--border);background:#fff;color:var(--muted);font-family:var(--fb);font-size:11px;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap}
.kb:hover{border-color:var(--navy2);color:var(--navy)}
.kb.ky{background:var(--gbg);border-color:var(--gbd);color:var(--green)}
.kb.kn{background:var(--rbg);border-color:var(--rbd);color:var(--red)}
.obsp{display:none;padding:0 13px 10px;background:#fff;animation:sd .2s ease}
.obsp.vis{display:block}
@keyframes sd{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.obsp textarea{width:100%;background:var(--rbg);border:1px solid var(--rbd);border-radius:var(--rs);padding:7px 10px;color:var(--text);font-family:var(--fb);font-size:12px;resize:vertical;min-height:48px;outline:none}
.oblbl{font-size:9px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--red);display:block;margin:8px 0 4px}

/* ── CASOS ── */
.rtabs{display:flex;gap:6px;margin-bottom:13px}
.rt{padding:5px 14px;border-radius:var(--rs);border:1.5px solid var(--border);background:var(--sf2);color:var(--muted);font-family:var(--fb);font-size:11.5px;font-weight:600;cursor:pointer;transition:all .18s}
.rt.on{background:var(--navy);border-color:var(--navy);color:#fff}
.cg{display:none}
.cg.on{display:block}
.cc{border:1px solid var(--border);border-radius:var(--rs);overflow:hidden;margin-bottom:7px;background:#fff}
.ch{display:flex;align-items:center;padding:11px 14px;gap:10px;cursor:pointer;background:var(--sf2);transition:background .15s;flex-wrap:wrap}
.ch:hover{background:var(--border2)}
.cttl{font-size:13px;font-weight:500;color:var(--text2);flex:1;line-height:1.4;font-family:var(--fb)}
.cest{display:flex;gap:5px;flex-shrink:0}
.eb{padding:4px 10px;border-radius:var(--rs);border:1.5px solid var(--border);background:#fff;color:var(--muted);font-size:10.5px;font-weight:600;cursor:pointer;transition:all .18s}
.eb.enp{background:var(--gbg);border-color:var(--gbd);color:var(--green)}
.eb.ep{background:var(--ybg);border-color:var(--ybd);color:var(--gold)}
.chev{color:var(--muted2);font-size:15px;transition:transform .22s;flex-shrink:0}
.chev.open{transform:rotate(180deg)}
.cbody{display:none;padding:0 14px 12px;background:#fff;animation:sd .2s ease}
.cbody.vis{display:block}
.cque{margin-top:10px;font-size:12.5px;color:var(--text2);line-height:1.6;background:var(--ybg);border-left:3px solid #d97706;padding:9px 12px;border-radius:0 var(--rs) var(--rs) 0;font-family:var(--fb)}
.cqlbl{font-size:9px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:#92400e;display:block;margin-bottom:5px}

/* ── ESTRELLAS ── */
.ei{background:var(--sf2);border:1px solid var(--border);border-radius:var(--rs);padding:14px 16px;margin-bottom:9px}
.ei p{font-size:13px;font-weight:500;color:var(--text2);margin-bottom:10px;font-family:var(--fb)}
.stars{display:flex;gap:3px}
.star{width:32px;height:32px;background:none;border:none;cursor:pointer;font-size:26px;color:var(--border);transition:color .15s,transform .1s;display:flex;align-items:center;justify-content:center;padding:0;line-height:1}
.star:hover,.star.on{color:#f59e0b}
.star:active{transform:scale(.87)}
.eta{width:100%;background:#fff;border:1px solid var(--border);border-radius:var(--rs);padding:9px 11px;color:var(--text);font-family:var(--fb);font-size:13px;resize:vertical;min-height:84px;outline:none}
.eta:focus{border-color:var(--navy2)}

/* ── RESULTADO ── */
.resbox{border-radius:var(--r);padding:26px 26px 22px;margin-bottom:18px;border:2px solid}
.resbox.apr{background:var(--gbg);border-color:var(--gbd)}
.resbox.rej{background:var(--rbg);border-color:var(--rbd)}
.restit{font-family:var(--ft);font-size:22px;font-weight:400;margin-bottom:4px}
.restit.gv{color:var(--green)}
.restit.rv{color:var(--red)}
.ressub{font-size:12.5px;color:var(--muted);margin-bottom:16px;font-family:var(--fb)}
.pbar-w{background:var(--border2);border-radius:100px;height:7px;overflow:hidden;margin-bottom:16px}
.pbar-f{height:100%;border-radius:100px;background:linear-gradient(to right,var(--navy2),var(--lime));transition:width .6s ease}
.res-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
@media(max-width:480px){.res-grid{grid-template-columns:1fr}}
.ri{background:#fff;border:1px solid var(--border);border-radius:var(--rs);padding:10px 13px;cursor:default}
.ri.clickable{cursor:pointer;transition:border-color .18s}
.ri.clickable:hover{border-color:var(--red)}
.ri .rl{font-size:9px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);margin-bottom:2px}
.ri .rv{font-size:13px;font-weight:600;color:var(--text);font-family:var(--fb)}
.ri .rv.ok{color:var(--green)}
.ri .rv.fail{color:var(--red)}
.ri .hint{font-size:10px;color:var(--muted2);margin-top:2px}

/* detalle items fallidos */
.fail-list{display:none;margin-top:10px;padding-top:10px;border-top:1px solid var(--rbd)}
.fail-list.vis{display:block}
.fail-item{font-size:12px;color:var(--red);padding:5px 9px;background:var(--rbg);border-radius:var(--rs);margin-bottom:5px;border-left:3px solid var(--rbd);font-family:var(--fb);line-height:1.4}

/* ── NAV BTNS ── */
.navb{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.bp{padding:8px 18px;border-radius:var(--rs);font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .18s}
.bnavy{background:var(--navy);color:#fff}
.bnavy:hover{background:var(--navy2)}
.bout{background:#fff;color:var(--navy);border:1.5px solid var(--border)}
.bout:hover{border-color:var(--navy2)}
.blime{background:var(--lime);color:var(--navy);font-weight:700}
.blime:hover{background:#d4ff00}

/* ── SAVE BAR ── */
.sbar{position:fixed;bottom:0;left:0;right:0;background:rgba(255,255,255,.95);backdrop-filter:blur(10px);border-top:1px solid var(--border);padding:11px 22px;display:flex;justify-content:flex-end;gap:8px;z-index:50}

/* ── TOAST ── */
.toast{position:fixed;bottom:64px;right:20px;background:var(--navy);color:#fff;font-family:var(--fb);font-size:12px;font-weight:600;padding:8px 16px;border-radius:var(--rs);opacity:0;transform:translateY(8px);transition:all .28s;pointer-events:none;z-index:999;box-shadow:var(--shm)}
.toast.show{opacity:1;transform:translateY(0)}

.divider{height:1px;background:var(--border2);margin:18px 0}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="tb-brand">
    <span class="dot"></span>
    <span class="name">Pasillo <em>Infinito</em></span>
  </div>
  <nav class="tab-nav">
    <button class="tbtn on" onclick="goTab(0)" id="tab0">Datos de la Tienda <span class="tpct" id="pct0">0%</span></button>
    <button class="tbtn" onclick="goTab(1)" id="tab1">Capacitacion <span class="tpct" id="pct1">0%</span></button>
    <button class="tbtn" onclick="goTab(2)" id="tab2">Acceso y Uso <span class="tpct" id="pct2">0%</span></button>
    <button class="tbtn" onclick="goTab(3)" id="tab3">Facturacion <span class="tpct" id="pct3">0%</span></button>
    <button class="tbtn" onclick="goTab(4)" id="tab4">Despacho <span class="tpct" id="pct4">0%</span></button>
    <button class="tbtn" onclick="goTab(5)" id="tab5">Materiales <span class="tpct" id="pct5">0%</span></button>
    <button class="tbtn" onclick="goTab(6)" id="tab6">Casos Frecuentes</button>
    <button class="tbtn" onclick="goTab(7)" id="tab7">Encuesta y Resultado</button>
  </nav>
  <div class="tb-right">
    <button class="bt bt-dr" onclick="guardarLocal()">Guardar borrador</button>
    <button class="bt bt-xl" onclick="exportarExcel()">Exportar Excel</button>
  </div>
</div>

<!-- ══ P0: DATOS TIENDA ══ -->
<div class="page on" id="page0"><div class="pi">

  <div class="hero">
    <div class="hbadge"><span class="dot"></span> Kit de Visita · 2026</div>
    <h1>Pasillo<em>Infinito</em></h1>
    <p class="hero-sub">No vendemos solo lo que esta en tienda. Con Pasillo Infinito vendemos lo que el cliente realmente quiere comprar.</p>
    <div class="hmeta">
      <div class="hmi"><div class="hl">Tipo de documento</div><div class="hv">Kit de Visita</div></div>
      <div class="hmi"><div class="hl">Fecha</div><div class="hv lime" id="hFecha">—</div></div>
      <div class="hmi"><div class="hl">Lider que te visita</div><div class="hv lime" id="hLider">—</div></div>
      <div class="hmi"><div class="hl">Tienda</div><div class="hv" id="hTienda">—</div></div>
    </div>
  </div>

  <div class="card">
    <div class="ctitle"><div class="ctl"><span class="ctbar"></span><h2>Informacion de la Visita</h2></div><span class="spct" id="spct0">0%</span></div>
    <div class="g3" style="margin-bottom:12px">
      <div class="field"><label>Nombre de la tienda</label><input class="fi" type="text" id="storeName" placeholder="Ej: Tienda Norte 045" oninput="syncH();p0()"></div>
      <div class="field"><label>Ciudad</label><input class="fi" type="text" id="storeCity" placeholder="Ej: Bogota" oninput="p0()"></div>
      <div class="field"><label>Fecha de visita</label><input class="fi" type="date" id="visitDate" oninput="syncH();p0()"></div>
    </div>
    <div class="g3" style="margin-bottom:18px">
      <div class="field">
        <label>Lider que te visita</label>
        <select class="fi" id="visitLeader" onchange="syncH();p0()">
          <option value="">Selecciona el lider</option>
          <option value="Daniela Marin">Daniela Marin</option>
          <option value="Valentina Cuineme">Valentina Cuineme</option>
          <option value="Valentina Urrego">Valentina Urrego</option>
        </select>
      </div>
      <div class="field"><label>Responsable de la tienda</label><input class="fi" type="text" id="visitResponsible" placeholder="Nombre" oninput="p0()"></div>
      <div class="field">
        <label>Cargo</label>
        <select class="fi" id="visitRole" onchange="p0()">
          <option value="">Selecciona el cargo</option>
          <option value="Administrador">Administrador</option>
          <option value="Coadministrador">Coadministrador</option>
        </select>
      </div>
    </div>
    <div class="sub">Integrantes de la tienda</div>
    <div class="drow">
      <div class="df"><label>Cajeros</label><input type="number" class="nin" min="0" id="numCajeros" placeholder="0" oninput="p0()"></div>
      <div class="df"><label>Asesores</label><input type="number" class="nin" min="0" id="numAsesores" placeholder="0" oninput="p0()"></div>
    </div>
  </div>

  <div class="navb"><button class="bp blime" onclick="goTab(1)">Continuar &rarr;</button></div>
</div></div>

<!-- ══ P1: CAPACITACION ══ -->
<div class="page" id="page1"><div class="pi">
  <div class="card">
    <div class="ctitle"><div class="ctl"><span class="ctbar"></span><h2>Asistencia a la Capacitacion</h2></div><span class="spct" id="spct1">0%</span></div>
    <div class="nr"><label>Tu como lider te conectaste a la capacitacion</label>
      <div class="tg"><button class="tgb" onclick="setTg(this,'lc','yes');p1()">Si</button><button class="tgb" onclick="setTg(this,'lc','no');p1()">No</button></div>
    </div>
    <div class="nr"><label>Cuantos de tus cajeros se conectaron a la capacitacion</label>
